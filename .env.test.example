# Variáveis de ambiente para testes E2E
# Copie este arquivo para .env.test e preencha os valores

# URL base do frontend (padrão do Vite)
E2E_BASE_URL=http://localhost:5173

# Credenciais de uma conta já existente no banco de teste (para testes de login)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Dados de uma conta pré-existente para testes de duplicidade (e-mail e CNPJ já cadastrados)
E2E_CONFLICT_EMAIL=conflito@e2e.licita.one
E2E_CONFLICT_CNPJ=
